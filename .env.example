NODE_ENV=development
PORT=8080
APP_ORIGIN=http://127.0.0.1:5173

# Generate a long random value before exposing this app.
JWT_SECRET=replace-with-a-long-random-secret

# OpenAI Image API
OPENAI_API_KEY=sk-your-openai-key
OPENAI_IMAGE_MODEL=gpt-image-2

# PayPal Standard Checkout
PAYPAL_ENABLED=false
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_CURRENCY=EUR

# Optional
STARTING_CREDITS=20
ROB_TOKEN_UPSCALE_8K_COST=5

# Storage backend. Supabase is the default app database.
# Use DATA_BACKEND=local only for isolated offline tests.
DATA_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only

# Optional local RTX/NVIDIA/localRTXup upscaler stage.
# Run `npm run rtx:sdk:download` to download NVIDIA Image Scaling SDK source if you want that route.
# For your localRTXup SDK layout, set LOCAL_RTXUP_DIR and adapt LOCAL_RTXUP_COMMAND to its readme.txt.
RTX_UPSCALER_ENABLED=false
RTX_UPSCALER_MODE=localRTXup

# localRTXup convention:
# 1. exactly one configured input PNG file
# 2. run the documented PowerShell command
# 3. read the configured output PNG file
LOCAL_RTXUP_DIR=C:\path\to\localRTXup
LOCAL_RTXUP_COMMAND=.\run.ps1
LOCAL_RTXUP_INPUT_FILE=input\4k.png
LOCAL_RTXUP_OUTPUT_FILE=output\8k.png
LOCAL_RTXUP_POWERSHELL=powershell.exe

# Example for your SwinIR folder:
# LOCAL_RTXUP_DIR=C:\Users\lrt71\Desktop\Desktop\Developer\localRTXup\my_upscaler
# LOCAL_RTXUP_COMMAND=.\run.ps1
# LOCAL_RTXUP_INPUT_FILE=input\input.png
# LOCAL_RTXUP_OUTPUT_FILE=output\out8k.png

# Generic CLI fallback mode. Use only when RTX_UPSCALER_MODE=cli.
RTX_UPSCALER_BIN=C:\path\to\rtx-upscaler.exe
RTX_UPSCALER_ARGS=--input {input} --output {output} --width {width} --height {height} --scale 2 --quality ultra
RTX_UPSCALER_TIMEOUT_MS=900000
